[fedora]
name=Fedora $releasever - $basearch
baseurl=http://fw.int.rhx/mirror/fedora/fedora/$releasever/$basearch/
enabled=1
countme=1
metadata_expire=7d
repo_gpgcheck=0
type=rpm
gpgcheck=1
gpgkey=file:///etc/pki/rpm-gpg/RPM-GPG-KEY-fedora-$releasever-$basearch
skip_if_unavailable=False

[updates]
name=Fedora $releasever - $basearch - Updates
baseurl=http://fw.int.rhx/mirror/fedora/fedora-updates/$releasever/$basearch/
enabled=1
countme=1
repo_gpgcheck=0
type=rpm
gpgcheck=1
metadata_expire=6h
gpgkey=file:///etc/pki/rpm-gpg/RPM-GPG-KEY-fedora-$releasever-$basearch
skip_if_unavailable=False

[updates-testing]
name=Fedora $releasever - $basearch - Updates testing
baseurl=http://fw.int.rhx/mirror/fedora/fedora-updates-testing/$releasever/$basearch/
